SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=30s

DB_HOST=postgres
DB_PORT=5432
DB_USER=insider
DB_PASSWORD=insider
DB_NAME=insider
DB_SSLMODE=disable
DB_MAX_CONNS=25

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

WORKER_POOL_SIZE=10
WORKER_RATE_LIMIT=100
WORKER_POLL_INTERVAL=100ms
WORKER_RETRY_BASE_WAIT=1s
WORKER_RETRY_MAX_WAIT=5m
WORKER_MAX_ATTEMPTS=5

PROVIDER_WEBHOOK_URL=https://webhook.site/unique-id
PROVIDER_REQUEST_TIMEOUT=10s
CB_MAX_FAILURES=5
CB_TIMEOUT=30s

OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
TRACING_ENABLED=true
